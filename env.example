# Server
NODE_ENV=production
PORT=3000
PUBLIC_SITE_URL=https://www.sankalpdigitalpathshala.online

# Runtime database used by the supplied Express app
MONGODB_URI=mongodb://mongo:27017/sankalp

# PostgreSQL target for the included Prisma enterprise schema
DATABASE_URL=postgresql://sankalp:sankalp_password@postgres:5432/sankalp_erp?schema=public

# Admin auth
ADMIN_EMAIL=admin@sankalpdigitalpathshala.online
ADMIN_PASSWORD=change-this-before-deploy
JWT_SECRET=replace-with-a-long-random-secret

# AI providers
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Cloudinary storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# S3-compatible storage target for future migration
S3_ENDPOINT=http://minio:9000
S3_REGION=auto
S3_BUCKET=sankalp-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
